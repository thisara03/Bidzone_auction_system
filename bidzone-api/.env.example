# Copy to .env for local runs.
#
# Native MySQL on Windows (no Docker) — use port 3306 after running scripts/init_bidzone_mysql_native.sql:
DATABASE_URL_SYNC=mysql+pymysql://bidzone:bidzone@127.0.0.1:3306/bidzone?charset=utf8mb4
#
# Docker Compose publishes MySQL on host 3307 (see docker-compose.yml). Then use:
# DATABASE_URL_SYNC=mysql+pymysql://bidzone:bidzone@127.0.0.1:3307/bidzone?charset=utf8mb4
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Production: comma-separated https origins for your deployed site, e.g.
# CORS_ORIGINS=https://your-app.netlify.app,https://www.yourdomain.com

# --- JWT (you should change in production) ---
# JWT_SECRET=...

# --- SMS OTP (Twilio) — you create account & paste values ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+15551234567
# SMS_DEMO_LOG_CODE=true
# OTP_PEPPER=
# OTP_TTL_MINUTES=10
# OTP_MAX_SENDS_PER_PHONE_HOUR=5
# OTP_MAX_SENDS_PER_IP_HOUR=25
# OTP_MAX_WRONG_ATTEMPTS=5
# TRUST_PROXY_FOR_CLIENT_IP=false

# --- Email (SendGrid) — you create API key & verify sender ---
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=noreply@your-verified-domain.com
