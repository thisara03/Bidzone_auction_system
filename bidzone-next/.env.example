# Copy to .env.local for local dev. On Vercel, add these in Project Settings → Environment Variables.

# ─── Vercel deploy checklist ───────────────────────────────────────────────
# 1. Import this repo on vercel.com → New Project
# 2. Set Root Directory to: bidzone-next  (required — app is not at repo root)
# 3. Add ALL variables below for Production (and Preview if you use preview deploys)
# 4. MongoDB Atlas → Network Access → allow 0.0.0.0/0 (or Vercel IPs) for cloud access
# 5. Google Cloud Console → OAuth client → add Authorized JavaScript origins:
#      https://YOUR-PROJECT.vercel.app
#    and Authorized redirect URIs if using redirect flow
# 6. Redeploy after saving environment variables

# Google OAuth 2.0 Web client ID (from Google Cloud Console)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Optional: separate API backend (leave unset when using Next.js /api routes on Vercel)
# NEXT_PUBLIC_API_URL=

# MongoDB Atlas connection string (include database name, e.g. /bidzone)
MONGODB_URI=mongodb+srv://<db_username>:<db_password>@cluster.mongodb.net/bidzone?retryWrites=true&w=majority

# JWT secret — use a long random string in production (openssl rand -base64 32)
JWT_SECRET=your_super_secret_jwt_key_here

# Admin allowlist — comma-separated emails granted admin on login (server env only)
ADMIN_EMAILS=admin@yourcompany.com
