# =============================================================================
# BidZone environment template — SAFE TO COMMIT (no real secrets)
# =============================================================================
#
# LOCAL SETUP:
#   1. Copy this file:  cp .env.example .env.local   (Windows: copy .env.example .env.local)
#   2. Fill in real values ONLY in .env.local
#   3. Never commit .env.local (it is gitignored)
#
# VERCEL / PRODUCTION:
#   Add each variable in Vercel → Project Settings → Environment Variables
#   Scope: Production + Preview + Development, then Redeploy.
#
# SECURITY:
#   - Rotate credentials if they were ever shared or committed
#   - JWT_SECRET: min 32 chars, cryptographically random
#   - MongoDB: use a dedicated DB user with least privilege (readWrite on one DB)
#   - ADMIN_EMAILS: server-only; never prefix with NEXT_PUBLIC_
#   - Only NEXT_PUBLIC_* variables are visible in the browser
#
# Generate a strong JWT secret:
#   openssl rand -base64 48
# =============================================================================

# ─── Public (embedded in client bundle — not secret, but restrict OAuth origins) ─
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs → Web client
# Must match this exact client ID. Add BOTH fields below (no trailing slash):
#   Authorized JavaScript origins: https://your-app.vercel.app , http://localhost:3000
#   Authorized redirect URIs:      https://your-app.vercel.app , http://localhost:3000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Optional separate API host (leave empty when using /api on same Vercel deployment)
# NEXT_PUBLIC_API_URL=

# ─── Server-only secrets (never NEXT_PUBLIC_) ─────────────────────────────────

# MongoDB Atlas — include database name in path, e.g. .../bidzone?retryWrites=true&w=majority
MONGODB_URI=

# Session signing key — openssl rand -base64 48
JWT_SECRET=

# Comma-separated super-admin emails (lowercase recommended)
ADMIN_EMAILS=
