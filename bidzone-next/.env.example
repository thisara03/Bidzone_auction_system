# Copy to .env.local for local dev. Never commit .env.local.

# Google OAuth 2.0 Web client ID (from Google Cloud Console)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Optional: FastAPI backend (no trailing slash)
# NEXT_PUBLIC_API_URL=http://localhost:8000

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<db_username>:<db_password>@bidzone.opintl9.mongodb.net/?appName=BidZone

# JWT secret — use a long random string in production
JWT_SECRET=your_super_secret_jwt_key_here
