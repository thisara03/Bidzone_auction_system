# Copy to .env.local for local dev. Never commit .env.local.

# Google OAuth 2.0 Web client ID (from Google Cloud Console)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Optional: FastAPI backend (no trailing slash)
# NEXT_PUBLIC_API_URL=http://localhost:8000

# MongoDB Atlas connection string (include database name, e.g. /bidzone)
MONGODB_URI=mongodb+srv://<db_username>:<db_password>@bidzone.opintl9.mongodb.net/bidzone?retryWrites=true&w=majority&appName=BidZone
# Atlas → Network Access: allow your IP (or 0.0.0.0/0 for local dev only)

# JWT secret — use a long random string in production
JWT_SECRET=your_super_secret_jwt_key_here

# Admin allowlist — comma-separated emails granted admin on login (server env only, never commit real emails to git)
ADMIN_EMAILS=admin@yourcompany.com
